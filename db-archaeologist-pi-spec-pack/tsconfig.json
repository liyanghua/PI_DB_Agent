{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "outDir": "dist",
    "lib": ["ES2022"]
  },
  "include": [
    "src/**/*.ts",
    "runtime/pi/extensions/**/*.ts",
    ".pi/extensions/**/*.ts",
    "tests/**/*.ts"
  ]
}