# DB Archaeologist pi spec-pack — local env sample
# 用法：cp .env.example .env，按需取消注释。绝不要把真实 key 提交进仓库。
#
# 启动命令本身不会自动 source .env；需要在 shell 中先 export，或者用 direnv：
#   set -a; source .env; set +a
#   pi
# 或者跳过 .env，进 pi 后用 /login 走 OAuth（凭据落 ~/.pi/agent/auth.json）。

# ─────────────────────────────────────────────
# 1. pi runtime —— 至少给一个 provider key
# ─────────────────────────────────────────────
# 任选其一即可；想多 provider 备份时可以同时填多个，pi 会按选择的 model 取对应 key。
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx
# OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxx

# 可选：跳过启动期版本检查/网络探活
# PI_OFFLINE=1

# ─────────────────────────────────────────────
# 2. spec-pack runtime —— 当前仅 REGISTRY_ROOT 真生效
# ─────────────────────────────────────────────
# 派生产物根目录。pi 工作目录就是 spec-pack 时无需设置；只有从外部工作目录调用时才需要指向 spec-pack 根。
# REGISTRY_ROOT=/absolute/path/to/db-archaeologist-pi-spec-pack

# 安全开关（当前是文档约定，contract probe / fs 写未上线时不读）。
LIVE_PROBE=false
ALLOW_FS_WRITE=false

# ─────────────────────────────────────────────
# 4. 数仓 API 出站凭据 —— 仅 probe_api_sample 工具会读取
# ─────────────────────────────────────────────
# probe_api_sample 会用这五个变量拼接真实请求；缺任何一个都会返回 status.blocked.reason=env_missing。
# 真正发起出站还需要把 LIVE_PROBE 切到 true，否则只走拼装、不联网。
# ZICHEN_BASE_URL=https://api.example.com
# ZICHEN_TENANT_ID=
# ZICHEN_USER_ID=
# ZICHEN_APP_CODE_KEY=
# ZICHEN_APP_CODE=

# ─────────────────────────────────────────────
# 3. 仅烟雾测试需要
# ─────────────────────────────────────────────
# scripts/pi_smoke.ts 用本地 typebox stub 跑通，不需要在日常使用中开启。
# DBA_PI_SMOKE=1