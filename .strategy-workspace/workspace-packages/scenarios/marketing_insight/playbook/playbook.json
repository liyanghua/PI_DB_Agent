{
  "schema_version": "business-strategy-playbook-v1",
  "scenario_id": "marketing_insight",
  "title": "市场分析洞察元策略",
  "coverage_status": "explicit",
  "runtime_profile": "pi_agent_v1",
  "source_collection_id": "marketing-insight-meta-strategy",
  "source_schema_version": "biz-strategy-meta-v2",
  "inputs": {
    "required": [
      "category",
      "date_range"
    ],
    "optional": [
      "platform",
      "seed_keywords",
      "target_price_band",
      "competitor_links",
      "shop_stage"
    ]
  },
  "nodes": [
    {
      "node_id": "define_scope",
      "title": "明确分析边界",
      "runtime": "strategy",
      "depends_on": [],
      "input_schema": {
        "required": [
          "category",
          "date_range"
        ],
        "optional": [
          "platform",
          "seed_keywords",
          "target_price_band",
          "competitor_links"
        ]
      },
      "runtime_request": {
        "kind": "hermes_request",
        "expected_output": "analysis_scope",
        "strategy_context": "market_insight"
      },
      "artifact_templates": [
        "analysis_scope"
      ],
      "failure_policy": "request_user_input",
      "rerun_policy": "allowed"
    },
    {
      "node_id": "industry_top300_analysis",
      "title": "行业 TOP300 分析",
      "runtime": "pi_agent",
      "depends_on": [
        "define_scope"
      ],
      "input_schema": {
        "required": [
          "category",
          "date_range"
        ],
        "optional": [
          "platform"
        ]
      },
      "runtime_request": {
        "kind": "pi_agent_request",
        "capability": "category_market_analysis",
        "tool": "analyze_category_top_products"
      },
      "artifact_templates": [
        "industry_top300_summary",
        "mainstream_product_structure"
      ],
      "failure_policy": "record_failure_and_continue",
      "rerun_policy": "allowed"
    },
    {
      "node_id": "keyword_demand_analysis",
      "title": "关键词需求分析",
      "runtime": "pi_agent",
      "depends_on": [
        "define_scope"
      ],
      "input_schema": {
        "required": [
          "category",
          "date_range"
        ],
        "optional": [
          "seed_keywords",
          "platform"
        ]
      },
      "runtime_request": {
        "kind": "pi_agent_request",
        "capability": "keyword_demand",
        "tool": "analyze_keyword_demand"
      },
      "artifact_templates": [
        "keyword_demand_table",
        "keyword_demand_summary"
      ],
      "failure_policy": "record_failure_and_block_dependents",
      "rerun_policy": "allowed"
    },
    {
      "node_id": "review_qa_pain_analysis",
